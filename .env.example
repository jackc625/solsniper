SOLSNIPER_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLSNIPER_RPC_BACKUP_URL=https://your-backup-rpc.example.com
SOLSNIPER_PRIVATE_KEY=your_base58_private_key_here
NODE_ENV=development
LOG_LEVEL=debug

# Detection source toggles — set to false to disable a listener
PUMPPORTAL_ENABLED=true
RAYDIUM_ENABLED=true
