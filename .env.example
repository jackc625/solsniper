# Primary Solana RPC -- sign up at helius.dev to get a free API key
SOLSNIPER_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Fallback RPC used if the primary is unreachable (can use public endpoint)
SOLSNIPER_RPC_BACKUP_URL=https://your-backup-rpc.example.com

# Base58 private key of the wallet that signs buy/sell transactions
# Export from Phantom: Settings → Security → Export Private Key
SOLSNIPER_PRIVATE_KEY=your_base58_private_key_here

# "development" or "production"
NODE_ENV=development

# Log verbosity: "debug" | "info" | "warn" | "error"
LOG_LEVEL=debug

# Detection source toggles -- set to false to disable a listener
PUMPPORTAL_ENABLED=true
RAYDIUM_ENABLED=true

# Safety pipeline API keys -- optional, enable advanced checks when present
# RUGCHECK_API_KEY=your_rugcheck_api_key_here   # rugcheck.xyz -- token rug risk scoring
# HELIUS_API_KEY=your_helius_api_key_here        # helius.dev -- token metadata enrichment

# Jupiter Swap API key -- REQUIRED. Free key at https://portal.jup.ag
SOLSNIPER_JUPITER_API_KEY=your_jupiter_api_key_here
